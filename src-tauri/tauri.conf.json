{
  "productName": "v-terminal",
  "version": "0.4.0",
  "identifier": "com.v-terminal.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "node scripts/build-daemon-dev.mjs && pnpm dev",
    "beforeBuildCommand": "node scripts/build-daemon-release.mjs && pnpm build",
    "beforeBundleCommand": ""
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "v-terminal",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "center": true,
        "visible": false
      },
      {
        "label": "splash",
        "title": "v-terminal",
        "url": "/splash.html",
        "width": 300,
        "height": 120,
        "decorations": false,
        "transparent": false,
        "resizable": false,
        "center": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": ["binaries/v-terminal-daemon"],
    "windows": {
      "wix": {},
      "nsis": {
        "installerHooks": "nsis/preinstall.nsh"
      }
    }
  }
}
