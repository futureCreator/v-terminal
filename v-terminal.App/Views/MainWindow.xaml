<Window
    x:Class="VTerminal.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VTerminal"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="v-terminal">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />   <!-- TitleBar -->
            <RowDefinition Height="36" />   <!-- TabBar -->
            <RowDefinition Height="36" />   <!-- SplitToolbar -->
            <RowDefinition Height="*" />    <!-- Content -->
        </Grid.RowDefinitions>

        <!-- Row 0: Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="32" VerticalAlignment="Top"
              Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />  <!-- App icon -->
                <ColumnDefinition Width="*" />     <!-- Title / Drag region -->
                <ColumnDefinition Width="Auto" />  <!-- System window buttons area -->
            </Grid.ColumnDefinitions>
            <Image Source="/Assets/Square44x44Logo.png" Width="16" Height="16"
                   Margin="12,0,8,0" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="v-terminal" VerticalAlignment="Center"
                       Margin="0,0,0,0"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
        </Grid>

        <!-- Row 1: Tab Bar -->
        <local:TabBar x:Name="TabBarControl" Grid.Row="1" />

        <!-- Row 2: Split Toolbar -->
        <local:SplitToolbar x:Name="SplitToolbarControl" Grid.Row="2" />

        <!-- Row 3: Content Area (PanelGrid + optional SidePanel) -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />       <!-- PanelGrid -->
                <ColumnDefinition Width="Auto" />    <!-- SidePanel (toolkit) -->
            </Grid.ColumnDefinitions>
            <local:PanelGrid x:Name="PanelGridControl" Grid.Column="0" />
            <local:SidePanel x:Name="SidePanelControl" Grid.Column="1"
                             Visibility="Collapsed" />
        </Grid>
    </Grid>
</Window>
