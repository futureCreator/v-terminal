<ContentDialog
    x:Class="VTerminal.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Uid="SettingsDialogTitle"
    Title="Settings"
    PrimaryButtonText="OK"
    CloseButtonText="Cancel"
    PrimaryButtonClick="OnPrimaryButtonClick"
    DefaultButton="Primary">

    <Pivot MinWidth="500" MinHeight="400">
        <!-- ===== Appearance Tab ===== -->
        <PivotItem x:Uid="SettingsAppearanceTab" Header="Appearance">
            <StackPanel Spacing="16" Padding="0,16">
                <!-- Theme -->
                <ComboBox x:Uid="SettingsTheme" Header="Theme"
                          x:Name="ThemeCombo" SelectedIndex="0"
                          HorizontalAlignment="Stretch">
                    <ComboBoxItem x:Uid="ThemeAuto" Content="Auto" Tag="auto" />
                    <ComboBoxItem x:Uid="ThemeLight" Content="Light" Tag="light" />
                    <ComboBoxItem x:Uid="ThemeDark" Content="Dark" Tag="dark" />
                </ComboBox>

                <!-- Language -->
                <ComboBox x:Uid="SettingsLanguage" Header="Language"
                          x:Name="LangCombo" SelectedIndex="0"
                          HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="English" Tag="en" />
                    <ComboBoxItem Content="&#xD55C;&#xAD6D;&#xC5B4;" Tag="ko" />
                </ComboBox>

                <!-- Note Background -->
                <ComboBox x:Uid="SettingsNoteBackground" Header="Note Background"
                          x:Name="NoteBgCombo" SelectedIndex="0"
                          HorizontalAlignment="Stretch">
                    <ComboBoxItem x:Uid="NoteBgNone" Content="None" Tag="none" />
                    <ComboBoxItem x:Uid="NoteBgRuled" Content="Ruled" Tag="ruled" />
                    <ComboBoxItem x:Uid="NoteBgGrid" Content="Grid" Tag="grid" />
                    <ComboBoxItem x:Uid="NoteBgDots" Content="Dots" Tag="dots" />
                </ComboBox>
            </StackPanel>
        </PivotItem>

        <!-- ===== Terminal Tab ===== -->
        <PivotItem x:Uid="SettingsTerminalTab" Header="Terminal">
            <StackPanel Spacing="16" Padding="0,16">
                <!-- Font family -->
                <ComboBox x:Uid="SettingsFont" Header="Font"
                          x:Name="FontCombo"
                          HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="JetBrains Mono" />
                    <ComboBoxItem Content="Fira Code" />
                    <ComboBoxItem Content="Cascadia Code" />
                    <ComboBoxItem Content="Cascadia Mono" />
                    <ComboBoxItem Content="Consolas" />
                    <ComboBoxItem Content="Courier New" />
                </ComboBox>

                <!-- Font size -->
                <NumberBox x:Uid="SettingsFontSize" Header="Font Size"
                           x:Name="FontSizeBox"
                           Minimum="10" Maximum="24" SmallChange="1"
                           Value="14"
                           SpinButtonPlacementMode="Inline" />

                <!-- Cursor style -->
                <RadioButtons x:Uid="SettingsCursorStyle" Header="Cursor Style"
                              x:Name="CursorStyleRadio">
                    <RadioButton x:Uid="CursorBlock" Content="Block" />
                    <RadioButton x:Uid="CursorUnderline" Content="Underline" />
                    <RadioButton x:Uid="CursorBar" Content="Bar" />
                </RadioButtons>

                <!-- Cursor blink -->
                <ToggleSwitch x:Uid="SettingsCursorBlink" Header="Cursor Blink"
                              x:Name="CursorBlinkToggle" IsOn="True" />

                <!-- Line height -->
                <Slider x:Uid="SettingsLineHeight" Header="Line Height"
                        x:Name="LineHeightSlider"
                        Minimum="1.0" Maximum="1.6"
                        StepFrequency="0.1"
                        Value="1.2"
                        TickPlacement="BottomRight"
                        TickFrequency="0.1" />

                <!-- Scrollback lines -->
                <NumberBox x:Uid="SettingsScrollback" Header="Scrollback Lines"
                           x:Name="ScrollbackBox"
                           Minimum="1000" Maximum="10000" SmallChange="1000"
                           Value="5000"
                           SpinButtonPlacementMode="Inline" />
            </StackPanel>
        </PivotItem>

        <!-- ===== General Tab ===== -->
        <PivotItem x:Uid="SettingsGeneralTab" Header="General">
            <StackPanel Spacing="16" Padding="0,16">
                <TextBlock x:Uid="SettingsGeneralDescription"
                           Text="General application settings"
                           Opacity="0.6" TextWrapping="Wrap" />

                <Button x:Uid="SettingsResetOnboarding"
                        Content="Reset Welcome Page"
                        Click="OnResetOnboardingClick" />
            </StackPanel>
        </PivotItem>
    </Pivot>
</ContentDialog>
