<ContentDialog
    x:Class="VTerminal.SshProfileDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Uid="SshProfileDialogTitle"
    Title="SSH Profiles"
    PrimaryButtonText="Save"
    CloseButtonText="Close"
    PrimaryButtonClick="OnSaveClick"
    DefaultButton="Primary">

    <Grid MinWidth="600" MinHeight="400">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />  <!-- Profile list -->
            <ColumnDefinition Width="*" />    <!-- Edit form -->
        </Grid.ColumnDefinitions>

        <!-- Left: Profile list -->
        <Grid Grid.Column="0"
              BorderThickness="0,0,1,0"
              BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
              Padding="0,0,8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ListView x:Name="ProfileList" Grid.Row="0"
                      SelectionMode="Single"
                      SelectionChanged="OnProfileSelected">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Padding="4" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4" Padding="0,8,0,0">
                <Button x:Uid="SshAddProfile" Content="+"
                        Click="OnAddProfileClick"
                        Width="36" Height="36" />
                <Button x:Uid="SshDeleteProfile" Content="-"
                        Click="OnDeleteProfileClick"
                        Width="36" Height="36" />
            </StackPanel>
        </Grid>

        <!-- Right: Edit form -->
        <StackPanel Grid.Column="1" Spacing="12" Padding="16,0,0,0"
                    x:Name="EditForm">
            <TextBox x:Uid="SshProfileName" Header="Name"
                     x:Name="NameBox"
                     PlaceholderText="My Server" />

            <TextBox x:Uid="SshProfileHost" Header="Host"
                     x:Name="HostBox"
                     PlaceholderText="192.168.1.100 or hostname" />

            <NumberBox x:Uid="SshProfilePort" Header="Port"
                       x:Name="PortBox"
                       Value="22" Minimum="1" Maximum="65535"
                       SpinButtonPlacementMode="Compact" />

            <TextBox x:Uid="SshProfileUsername" Header="Username"
                     x:Name="UsernameBox"
                     PlaceholderText="root" />

            <TextBox x:Uid="SshProfileIdentityFile" Header="Identity File (optional)"
                     x:Name="IdentityBox"
                     PlaceholderText="C:\Users\...\.ssh\id_rsa" />

            <Button x:Uid="SshBrowseIdentity" Content="Browse..."
                    Click="OnBrowseIdentityClick" />

            <!-- Connection test -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Uid="SshTestConnection" Content="Test Connection"
                        Click="OnTestConnectionClick" />
                <TextBlock x:Name="TestResultText"
                           VerticalAlignment="Center"
                           FontSize="12" Opacity="0.7" />
            </StackPanel>
        </StackPanel>
    </Grid>
</ContentDialog>
