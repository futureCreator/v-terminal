<UserControl
    x:Class="VTerminal.TodoView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Input area -->
            <RowDefinition Height="*" />     <!-- Todo list -->
            <RowDefinition Height="Auto" />  <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Input area: TextBox + Add button -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="TodoInput" Grid.Column="0"
                     x:Uid="TodoInputPlaceholder"
                     PlaceholderText="Add a task..."
                     KeyDown="OnInputKeyDown"
                     Margin="0,0,4,0" />

            <Button x:Name="AddButton" Grid.Column="1"
                    x:Uid="TodoAddButton"
                    Content="Add"
                    Click="OnAddClick" />
        </Grid>

        <!-- Todo list -->
        <ListView x:Name="TodoList" Grid.Row="1"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />  <!-- Checkbox -->
                            <ColumnDefinition Width="*" />     <!-- Text -->
                            <ColumnDefinition Width="Auto" />  <!-- Delete -->
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding Completed}"
                                  Click="OnTodoToggle"
                                  Tag="{Binding Id}"
                                  MinWidth="0" />

                        <TextBlock Grid.Column="1"
                                   Text="{Binding Text}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="4,0" />

                        <Button Grid.Column="2"
                                Content="&#xE74D;"
                                FontFamily="Segoe MDL2 Assets"
                                Click="OnTodoDelete"
                                Tag="{Binding Id}"
                                Width="28" Height="28"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Footer: count + clear completed -->
        <Grid Grid.Row="2" Padding="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="RemainingCount" Grid.Column="0"
                       VerticalAlignment="Center"
                       Opacity="0.6"
                       FontSize="12" />

            <Button x:Name="ClearCompletedBtn" Grid.Column="1"
                    x:Uid="TodoClearCompleted"
                    Content="Clear completed"
                    Click="OnClearCompletedClick"
                    FontSize="12"
                    Padding="8,4"
                    Background="Transparent"
                    BorderThickness="0" />
        </Grid>
    </Grid>
</UserControl>
